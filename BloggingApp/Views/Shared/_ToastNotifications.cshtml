@if (TempData["Success"] != null)
{
    <div class="toast align-items-center text-bg-success border-0 toast-auto-show"
         role="alert"
         data-delay="5000">
        <div class="d-flex">
            <div class="toast-body">
                <i class="bi bi-check-circle-fill me-2"></i>
                @TempData["Success"]
            </div>
            <button type="button"
                    class="btn-close btn-close-white me-2 m-auto"
                    data-bs-dismiss="toast">
            </button>
        </div>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="toast align-items-center text-bg-danger border-0 toast-auto-show"
         role="alert"
         data-delay="5000">
        <div class="d-flex">
            <div class="toast-body">
                <i class="bi bi-x-circle-fill me-2"></i>
                @TempData["Error"]
            </div>
            <button type="button"
                    class="btn-close btn-close-white me-2 m-auto"
                    data-bs-dismiss="toast">
            </button>
        </div>
    </div>
}

@if (TempData["Warning"] != null)
{
    <div class="toast align-items-center text-bg-warning border-0 toast-auto-show"
         role="alert"
         data-delay="5000">
        <div class="d-flex">
            <div class="toast-body">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                @TempData["Warning"]
            </div>
            <button type="button"
                    class="btn-close me-2 m-auto"
                    data-bs-dismiss="toast">
            </button>
        </div>
    </div>
}
