@model IEnumerable<UsersViewModel>

@{
    ViewData["Title"] = "Manage Users";
}

<div class="container-fluid mt-4">

    <div class="card shadow-lg border-0 rounded-4">

        <div class="card-header bg-primary text-white">

            <div class="d-flex justify-content-between align-items-center">

                <div>
                    <h3 class="mb-0">
                        <i class="bi bi-people-fill"></i>
                        User Management
                    </h3>
                </div>

                <a asp-action="Register" asp-Controller="Auth"
                   class="btn btn-light">

                    <i class="bi bi-person-plus-fill"></i>

                    Create New User

                </a>

            </div>

        </div>


        <div class="card-body">

            <form method="get">

                <div class="row mb-4">

                    <div class="col-md-6">

                        <div class="input-group">

                            <span class="input-group-text">

                                <i class="bi bi-search"></i>

                            </span>

                            <input name="search"

                                   value="@Context.Request.Query["search"]"

                                   class="form-control"

                                   placeholder="Search by name, email or role..." />

                        </div>

                    </div>

                    <div class="col-md-2">

                        <button class="btn btn-primary w-100">

                            Search

                        </button>

                    </div>

                    <div class="col-md-2">

                        <a asp-action="Index"

                           class="btn btn-outline-secondary w-100">

                            Reset

                        </a>

                    </div>

                </div>

            </form>


            <div class="table-responsive">

                <table class="table table-hover align-middle">

                    <thead class="table-dark">

                        <tr>

                            <th>Name</th>

                            <th>Email</th>

                            <th>Phone</th>

                            <th>Role</th>

                            <th>Status</th>

                            <th class="text-center">Actions</th>

                        </tr>

                    </thead>

                    <tbody>

                        @if (Model.Any())
                        {
                            foreach (var user in Model)
                            {
                                <tr>

                                    <td>

                                        <div class="d-flex align-items-center">

                                            <img src="@(string.IsNullOrWhiteSpace(user.ProfilePictureUrl)
                                                ? "/images/default-avatar.png"
                                                : user.ProfilePictureUrl)"

                                                 class="rounded-circle border me-3"

                                                 width="50"

                                                 height="50"

                                                 style="object-fit:cover;" />

                                            <div>

                                                <strong>

                                                    @user.FullName

                                                </strong>

                                                <br />

                                                <small class="text-muted">

                                                    @user.FullName

                                                </small>

                                            </div>

                                        </div>

                                    </td>

                                    <td>

                                        @user.Email

                                    </td>

                                    <td>

                                        @user.PhoneNumber

                                    </td>

                                    <td>

                                        <span class="badge bg-info">

                                            @user.SelectedRole

                                        </span>

                                    </td>

                                    <td>

                                        @if (user.IsActive)
                                        {
                                            <span class="badge bg-success">

                                                Active

                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">

                                                Inactive

                                            </span>
                                        }

                                    </td>

                                    <td class="text-center">

                                        @* <a asp-action="Details"
                                           asp-route-id="@user.Id"
                                           class="btn btn-outline-info btn-sm">

                                            <i class="bi bi-eye"></i>

                                        </a> *@

                                        <a asp-action="EditProfile"
                                           asp-controller="Auth"
                                           asp-route-userId="@user.UserId"
                                           class="btn btn-outline-warning btn-sm">

                                            <i class="bi bi-pencil-square"></i>

                                        </a>
                                        @if(user.IsActive)
                                        {
                                            <button class="btn btn-outline-danger btn-sm"

                                                    onclick="confirmDelete('@user.UserId')">

                                                <i class="bi bi-trash"></i>

                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-outline-success btn-sm"
                                                    onclick="confirmDelete('@user.UserId')">

                                                <i class="bi bi-check-circle-fill"></i>

                                            </button>
                                        }
                                    </td>

                                </tr>
                            }
                        }
                        else
                        {
                            <tr>

                                <td colspan="6"
                                    class="text-center text-muted py-5">

                                    <h5>No users found.</h5>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

            <nav>

                <ul class="pagination justify-content-end">

                    <li class="page-item disabled">

                        <a class="page-link">

                            Previous

                        </a>

                    </li>

                    <li class="page-item active">

                        <a class="page-link">

                            1

                        </a>

                    </li>

                    <li class="page-item">

                        <a class="page-link">

                            Next

                        </a>

                    </li>

                </ul>

            </nav>

        </div>

    </div>

</div>

<form id="deleteForm"
      asp-action="Delete"
      asp-controller="Auth"
      method="post">

    @Html.AntiForgeryToken()

    <input type="hidden"
           id="deleteUserId"
           name="id" />

</form>

@section Scripts{

<script>

    function confirmDelete(id){

        if(confirm("Are you sure you want to activate/reactivate this user?")){

            document.getElementById("deleteUserId").value=id;

            document.getElementById("deleteForm").submit();

        }

    }

</script>

}
