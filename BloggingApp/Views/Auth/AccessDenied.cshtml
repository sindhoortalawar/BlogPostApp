@{
    ViewData["Title"] = "Access Denied";
}

<div class="container my-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0 py-5 px-4 bg-white rounded-3">
                <div class="card-body">
                    <div class="text-danger mb-4">
                        <i class="bi bi-shield-slash" style="font-size: 4rem;"></i>
                    </div>
                    <h2 class="fw-bold text-dark mb-2">Restricted Access</h2>
                    <p class="text-muted mb-4">
                        You do not have the required administrative clearance or security roles to access this page.
                    </p>
                    <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
                        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-primary px-4 py-2 fw-semibold shadow-sm">
                            Return to Dashboard
                        </a>
                        <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                            <button type="submit" class="btn btn-outline-secondary px-4 py-2">
                                Switch Account
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>